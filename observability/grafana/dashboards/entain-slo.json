      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 19 },
      "id": 17,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } },
      "targets": [
        {
          "expr": "sum(rate(entain_http_requests_total{status=~\"5..\"}[1m])) or vector(0)",
          "legendFormat": "SERVICE: 5xx",
          "refId": "A"
        },
        {
          "expr": "sum(rate(entain_transactions_rejected_total[1m])) or vector(0)",
