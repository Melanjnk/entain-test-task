{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "SLI / SLO / SLA (balance API)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "SLI: share of HTTP 2xx responses. SLO target: 99.9% monthly availability.",
      "fieldConfig": {
        "defaults": {
          "decimals": 3,
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.99 },
              { "color": "green", "value": 0.999 }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "id": 2,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "entain:sli:availability:ratio",
          "legendFormat": "availability",
          "refId": "A"
        }
      ],
      "title": "Availability SLI",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "SLI: p95 request latency. SLO target: < 100ms for POST /transaction at 30 RPS.",
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.1 },
              { "color": "red", "value": 0.25 }
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 1 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "entain:sli:latency:p95_seconds",
          "legendFormat": "p95"
        }
      ],
      "title": "Latency SLI (p95)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Task requirement: sustain 20–30 RPS (markers on arc). Gray = idle. Green = target met. Run `make load-25` to validate.",
      "fieldConfig": {
        "defaults": {
          "decimals": 1,
          "max": 60,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#9CA3AF", "value": null },
              { "color": "#FADE2A", "value": 1 },
              { "color": "#73BF69", "value": 20 },
              { "color": "#73BF69", "value": 30 },
              { "color": "#73BF69", "value": 40 },
              { "color": "#FF9830", "value": 50 },
              { "color": "#F2495C", "value": 80 }
            ]
          },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 1 },
      "id": 4,
      "options": {
        "minVizHeight": 75,
        "minVizWidth": 75,
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": true,
        "showThresholdMarkers": true,
        "sizing": "auto"
      },
      "targets": [
        {
          "expr": "entain:sli:request_rate_rps",
          "legendFormat": "__auto",
          "refId": "A"
        }
      ],
      "title": "Load Target",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "SLI: applied / (applied + rejected). Business correctness under validation rules.",
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.95 },
              { "color": "green", "value": 0.99 }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 1 },
      "id": 5,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "entain:sli:transaction_success:ratio",
          "legendFormat": "tx success",
          "refId": "A"
        }
      ],
      "title": "Transaction Success SLI",
      "type": "stat"
